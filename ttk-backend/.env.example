DATABASE_URL=postgresql+asyncpg://ttk:ttk_pass@localhost:5432/ttk_radio
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MEDIA_DIR=./media
MAX_AUDIO_MB=50
MAX_VIDEO_MB=1000
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# Email (SMTP) — для восстановления пароля
# Оставьте пустым для dev-режима (ссылка выводится в логи Docker)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ttk.ru
SMTP_FROM_NAME=ТТК Эфирная платформа
FRONTEND_URL=http://localhost:80
